@{
    ViewData["Title"] = "Sobre o Projeto";
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="card shadow mb-4">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-info-circle"></i> Sobre o AgroSolidario
            </div>
            <div class="card-body text-center py-5">
                <div style="font-size: 5rem;">🌱</div>
                <h2 class="fw-bold mt-3">AgroSolidario</h2>
                <p class="text-muted fs-5">Sistema de Gestão de Doações de Alimentos</p>
                <hr />
                <p class="lead">
                    O <strong>AgroSolidario</strong> é uma plataforma desenvolvida para facilitar
                    a gestão de doações de alimentos, conectando doadores a beneficiários como
                    escolas, ONGs, hospitais e famílias carentes.
                </p>
            </div>
        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card shadow text-center h-100">
                    <div class="card-body py-4">
                        <i class="bi bi-heart-fill text-danger" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold mt-3">Missão</h5>
                        <p class="text-muted">Reduzir o desperdício de alimentos e combater a fome conectando quem tem a quem precisa.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow text-center h-100">
                    <div class="card-body py-4">
                        <i class="bi bi-eye-fill text-primary" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold mt-3">Visão</h5>
                        <p class="text-muted">Ser referência em sistemas de gestão de doações, promovendo solidariedade e sustentabilidade.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow text-center h-100">
                    <div class="card-body py-4">
                        <i class="bi bi-star-fill text-warning" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold mt-3">Valores</h5>
                        <p class="text-muted">Solidariedade, transparência, responsabilidade social e respeito às pessoas.</p>
                    </div>
                </div>
            </div>

        </div>

        <div class="card shadow mb-4">
            <div class="card-header bg-white fw-bold">
                <i class="bi bi-tools"></i> Tecnologias Utilizadas
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4 text-center">
                        <span class="badge bg-primary fs-6 p-2 w-100">ASP.NET Core MVC</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <span class="badge bg-success fs-6 p-2 w-100">Entity Framework Core</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <span class="badge bg-dark fs-6 p-2 w-100">SQLite</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <span class="badge bg-info fs-6 p-2 w-100">Bootstrap 5</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <span class="badge bg-warning text-dark fs-6 p-2 w-100">QuestPDF</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <span class="badge bg-secondary fs-6 p-2 w-100">Chart.js</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-header bg-white fw-bold">
                <i class="bi bi-person-badge"></i> Desenvolvedor
            </div>
            <div class="card-body text-center py-4">
                <i class="bi bi-person-circle text-success" style="font-size:4rem;"></i>
                <h5 class="fw-bold mt-3">Kevin</h5>
                <p class="text-muted">Desenvolvedor do sistema AgroSolidario</p>
                <span class="badge bg-danger">ADMIN</span>
            </div>
        </div>

    </div>
</div>