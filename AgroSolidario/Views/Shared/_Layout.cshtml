<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgroSolidario</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-success shadow mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    🌱 AgroSolidario
                </a>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Alimentos" asp-action="Index">
                                <i class="bi bi-box-seam"></i> Alimentos
                            </a>
                        </li>

                        @if (Context.Session.GetString("UsuarioTipo") == "ADMIN")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuarios" asp-action="Index">
                                    <i class="bi bi-people"></i> Usuários
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Relatorio" asp-action="GerarPDF">
                                <i class="bi bi-file-earmark-pdf"></i> Relatório PDF
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Historico" asp-action="Index">
                                <i class="bi bi-clock-history"></i> Histórico
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="About" asp-action="Index">
                                <i class="bi bi-info-circle"></i> Sobre
                            </a>
                        </li>

                        <li class="nav-item ms-auto">
                            <a class="nav-link text-white" asp-controller="Login" asp-action="Perfil">
                                <i class="bi bi-person-circle"></i> @Context.Session.GetString("UsuarioNome")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-warning" asp-controller="Login" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Sair
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-success text-white mt-4 py-3 shadow-lg">
        <div class="container text-center">
            <p class="mb-1">
                🌱 <strong>AgroSolidario</strong> — Sistema de Gestão de Doações
            </p>
            <p class="mb-0 opacity-75" style="font-size:0.85rem;">
                &copy; @DateTime.Now.Year AgroSolidario. Todos os direitos reservados.
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>