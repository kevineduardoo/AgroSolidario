@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4 fw-bold">📊 Dashboard</h2>

@if (ViewBag.AlimentosVencendo != null && ViewBag.AlimentosVencendo.Count > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4 shadow-sm">
        <i class="bi bi-exclamation-triangle-fill me-2" style="font-size:1.5rem;"></i>
        <div>
            <strong>Atenção!</strong> @ViewBag.AlimentosVencendo.Count alimento(s) vencem nos próximos 30 dias.
        </div>
    </div>
}

<div class="row g-4 mb-4">

    <div class="col-md-4">
        <div class="card text-white bg-primary shadow">
            <div class="card-body text-center">
                <i class="bi bi-people-fill" style="font-size:2rem;"></i>
                <h5 class="card-title mt-2">Total de Usuários</h5>
                <h1 class="fw-bold">@ViewBag.TotalUsuarios</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success shadow">
            <div class="card-body text-center">
                <i class="bi bi-box-seam-fill" style="font-size:2rem;"></i>
                <h5 class="card-title mt-2">Total de Alimentos</h5>
                <h1 class="fw-bold">@ViewBag.TotalAlimentos</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-danger shadow">
            <div class="card-body text-center">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:2rem;"></i>
                <h5 class="card-title mt-2">Próximos da Validade</h5>
                <h1 class="fw-bold">@ViewBag.ProximosValidade</h1>
            </div>
        </div>
    </div>

</div>

<div class="row g-4 mb-4">

    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-white fw-bold">
                📊 Distribuição de Usuários
            </div>
            <div class="card-body">
                <canvas id="graficoUsuarios"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-white fw-bold">
                📦 Resumo do Sistema
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-shield-fill text-danger me-2"></i> Administradores</span>
                        <span class="badge bg-danger rounded-pill">@ViewBag.TotalAdmins</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-heart-fill text-success me-2"></i> Doadores</span>
                        <span class="badge bg-success rounded-pill">@ViewBag.TotalDoadores</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-people-fill text-primary me-2"></i> Beneficiários</span>
                        <span class="badge bg-primary rounded-pill">@ViewBag.TotalBeneficiarios</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <i class="bi bi-box-seam-fill text-warning me-2"></i> Total de Alimentos
                        <span class="badge bg-warning text-dark rounded-pill">@ViewBag.TotalAlimentos</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

</div>

@if (ViewBag.AlimentosVencendo != null && ViewBag.AlimentosVencendo.Count > 0)
{
    <div class="card shadow mb-4 border-warning">
        <div class="card-header bg-warning fw-bold">
            ⚠️ Alimentos Próximos da Validade
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-warning">
                    <tr>
                        <th>Nome</th>
                        <th>Quantidade</th>
                        <th>Destino</th>
                        <th>Validade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.AlimentosVencendo)
                    {
                        <tr>
                            <td>@item.Nome</td>
                            <td>@item.Quantidade</td>
                            <td>@item.Destino</td>
                            <td class="text-danger fw-bold">@item.Validade.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-header bg-white fw-bold">
        ⚡ Acesso Rápido
    </div>
    <div class="card-body">
        <a asp-controller="Alimentos" asp-action="Create" class="btn btn-success me-2">
            <i class="bi bi-plus-circle"></i> Novo Alimento
        </a>
        <a asp-controller="Usuarios" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Novo Usuário
        </a>
    </div>
</div>

<div class="card shadow">
    <div class="card-header bg-white fw-bold">
        🕐 Últimos Alimentos Cadastrados
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-success">
                <tr>
                    <th>Nome</th>
                    <th>Quantidade</th>
                    <th>Destino</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.UltimosAlimentos)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.Quantidade</td>
                        <td>@item.Destino</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('graficoUsuarios').getContext('2d');
    new Chart(ctx, {
    type: 'doughnut',
    data: {
    labels: ['Administradores', 'Doadores', 'Beneficiários'],
    datasets: [{
    data: [@ViewBag.TotalAdmins, @ViewBag.TotalDoadores, @ViewBag.TotalBeneficiarios],
    backgroundColor: ['#dc3545', '#198754', '#0d6efd'],
    borderWidth: 2
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: {
    position: 'bottom'
    }
    }
    }
    });
</script>