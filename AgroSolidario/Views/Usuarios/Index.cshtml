@model IEnumerable<AgroSolidario.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">👥 Lista de Usuários</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Novo Usuário
    </a>
</div>

<div class="card shadow">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Tipo</th>
                    <th>Instituição</th>
                    <th>Endereço</th>
                    <th>Telefone</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.Email</td>
                        <td>
                            <span class="badge bg-@(item.Tipo == "ADMIN" ? "danger" : item.Tipo == "Doador" ? "success" : "primary")">
                                @item.Tipo
                            </span>
                        </td>
                        <td>
                            @if (item.Tipo == "Beneficiario" && item.TipoInstituicao != null)
                            {
                                <span class="badge bg-info text-dark">@item.TipoInstituicao</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (item.Tipo == "Beneficiario" && item.Endereco != null)
                            {
                                @item.Endereco
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (item.Tipo == "Beneficiario" && item.Telefone != null)
                            {
                                @item.Telefone
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>