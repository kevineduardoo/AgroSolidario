@model AgroSolidario.Models.Alimento

@{
    ViewData["Title"] = "Novo Alimento";
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-plus-circle"></i> Cadastrar Alimento
            </div>
            <div class="card-body">

                <form asp-action="Create" method="post" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome</label>
                        <input asp-for="Nome" class="form-control" placeholder="Nome do alimento" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantidade</label>
                        <input asp-for="Quantidade" class="form-control" placeholder="Quantidade em kg ou unidades" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Doador</label>
                        <input asp-for="Doador" class="form-control" placeholder="Nome do doador" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Destino</label>
                        <input asp-for="Destino" class="form-control" placeholder="Destino da doação" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Validade</label>
                        <input asp-for="Validade" type="date" class="form-control" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Foto do Alimento</label>
                        <input type="file" name="foto" class="form-control" accept="image/*" />
                        <small class="text-muted">Opcional — JPG, PNG, etc.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Salvar
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Voltar
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>