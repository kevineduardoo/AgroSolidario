@model AgroSolidario.Models.Usuario

@{
    ViewData["Title"] = "Criar Conta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AgroSolidario — Criar Conta</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background: linear-gradient(135deg, #198754, #0d6efd);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .card {
                border: none;
                border-radius: 16px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.25);
            }

            .card-header {
                background: #198754;
                border-radius: 16px 16px 0 0 !important;
                padding: 2rem;
                text-align: center;
                color: white;
            }
    </style>
</head>
<body>

    <div style="width: 100%; max-width: 480px; padding: 1rem;">
        <div class="card">

            <div class="card-header">
                <div style="font-size: 3rem;">🌱</div>
                <h2 class="fw-bold mb-0">AgroSolidario</h2>
                <p class="mb-0 opacity-75">Criar nova conta</p>
            </div>

            <div class="card-body p-4">

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @ViewBag.Erro
                    </div>
                }

                <form asp-action="Cadastro" method="post">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nome</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-person"></i>
                            </span>
                            <input asp-for="Nome" class="form-control" placeholder="Seu nome completo" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="form-control" placeholder="seu@email.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Senha</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input asp-for="Senha" type="password" class="form-control" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Tipo de Conta</label>
                        <select asp-for="Tipo" class="form-select" id="tipoConta" required>
                            <option value="">Selecione...</option>
                            <option value="Doador">Doador</option>
                            <option value="Beneficiario">Beneficiário</option>
                        </select>
                    </div>

                    <div id="camposBeneficiario" style="display:none;">
                        <hr />
                        <p class="fw-bold text-primary">
                            <i class="bi bi-building"></i> Informações do Beneficiário
                        </p>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tipo de Instituição</label>
                            <select asp-for="TipoInstituicao" class="form-select">
                                <option value="">Selecione...</option>
                                <option value="Escola">Escola</option>
                                <option value="ONG">ONG</option>
                                <option value="Família">Família Carente</option>
                                <option value="Hospital">Hospital</option>
                                <option value="Outro">Outro</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Endereço</label>
                            <input asp-for="Endereco" class="form-control" placeholder="Rua, número, bairro, cidade" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Telefone para Contato</label>
                            <input asp-for="Telefone" class="form-control" placeholder="(00) 00000-0000" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 mb-3">
                        <i class="bi bi-person-check me-2"></i> Criar Conta
                    </button>

                    <hr />

                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left me-2"></i> Já tenho conta
                    </a>

                </form>

            </div>
        </div>

        <p class="text-center text-white mt-3 opacity-75" style="font-size:0.85rem;">
            AgroSolidario &copy; @DateTime.Now.Year
        </p>
    </div>

    <script>
            document.getElementById('tipoConta').addEventListener('change', function () {
                const campos = document.getElementById('camposBeneficiario');
                campos.style.display = this.value === 'Beneficiario' ? 'block' : 'none';
            });
    </script>

</body>
</html>